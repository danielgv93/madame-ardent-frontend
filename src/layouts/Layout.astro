---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import TopMenu from "./TopMenu.astro";
import Footer from "./Footer.astro";
import Lightbox from "../components/Lightbox.astro";
import CartDrawer from "../components/shop/CartDrawer";
import { getLangFromUrl, getAlternateUrl, useTranslations, localizedRoute } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'product' | 'article';
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = "Madame Ardent",
	description,
	ogImage,
	ogType = 'website',
	jsonLd,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const altLang = lang === 'es' ? 'en' : 'es';
const alternateHref = getAlternateUrl(Astro.url, altLang);
const canonicalPath = Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const resolvedOgImage = ogImage
	? new URL(ogImage, Astro.site ?? Astro.url).toString()
	: undefined;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const t = useTranslations(lang);

const cartDrawerLabels = {
	title: t('cart.title'),
	titleEmph: t('cart.titleEmph'),
	close: t('cart.closeLabel'),
	empty: t('cart.empty'),
	subtotal: t('cart.subtotal'),
	checkout: t('cart.checkout'),
	clear: t('cart.clear'),
	remove: t('cart.remove'),
	loading: t('cart.loading'),
	currencyLabel: t('shop.currencyLabel'),
	cartHref: localizedRoute('cart', lang),
	viewCart: t('cart.viewCart'),
};
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/madame-ardent.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang={lang} href={canonicalPath} />
		<link rel="alternate" hreflang={altLang} href={alternateHref} />
		<ClientRouter />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
		{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
		<meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		{resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
		{jsonLdArray.map((data) => (
			<script type="application/ld+json" set:html={JSON.stringify(data)} />
		))}
	</head>
	<body>
	<TopMenu />
	<div id="container" class="pt-24">
		<slot />
	</div>
	<Footer />
	<Lightbox />
	<CartDrawer client:load lang={lang} labels={cartDrawerLabels} />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
