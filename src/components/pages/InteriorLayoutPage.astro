---
import Section from "../../layouts/Section.astro";
import Title from "../Title.astro";
import Text from "../Text.astro";
import Row from "../Row.astro";
import Col from "../Col.astro";
import Button from "../Button.astro";
import ZoomableImage from "../ZoomableImage.astro";
import { getLangFromUrl, useTranslations, localizedRoute } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tiers = t('interiorLayout.tiers') as unknown as { range: string; price: string }[];
---

<Section>
    <Row class="items-center md:gap-12 gap-8 flex-col md:flex-row">
        <Col class="md:w-1/2 w-full md:px-6 px-0 items-start order-2 md:order-1">
            <Title class="md:text-5xl text-4xl md:leading-16">
                {t('interiorLayout.title')} <span class="italic">{t('interiorLayout.titleEmph')}</span>
            </Title>

            <ul class="flex flex-col gap-4 mt-8 w-full">
                {tiers.map((tier) => (
                    <li class="flex items-baseline justify-between gap-4 border-b border-primary/20 pb-3">
                        <Text>{tier.range}</Text>
                        <span class="text-primary font-simplify text-2xl md:text-3xl whitespace-nowrap">{tier.price}</span>
                    </li>
                ))}
            </ul>

            <Text class="mt-6 text-secondary-500">
                {t('interiorLayout.epubNoteStart')}<span class="text-primary font-simplify">{t('interiorLayout.epubNoteAmount')}</span>{t('interiorLayout.epubNoteEnd')}
            </Text>

            <Text class="mt-4 text-sm text-secondary-500 italic">
                {t('interiorLayout.disclaimer')}
            </Text>

            <a href={localizedRoute('contact', lang)} class="mt-8">
                <Button variant="primary" size="lg">{t('common.requestQuote')}</Button>
            </a>
        </Col>
        <Col class="md:w-1/2 w-full order-1 md:order-2">
            <ZoomableImage class="rounded-xl w-full" src="/servicios/maquetacion-fisico.webp" alt={`${t('interiorLayout.title')} ${t('interiorLayout.titleEmph')}`} />
        </Col>
    </Row>
</Section>
