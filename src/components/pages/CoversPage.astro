---
import Section from "../../layouts/Section.astro";
import Title from "../Title.astro";
import Text from "../Text.astro";
import Row from "../Row.astro";
import Col from "../Col.astro";
import Button from "../Button.astro";
import ZoomableImage from "../ZoomableImage.astro";
import { getLangFromUrl, useTranslations, localizedRoute } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const covers = [
    { name: t('covers.simple'),             price: t('covers.priceSimple'),             image: "/servicios/simple.webp" },
    { name: t('covers.manipulated'),        price: t('covers.priceManipulated'),        image: "/servicios/fotomanipulacion.webp" },
    { name: t('covers.illustratedSimple'),  price: t('covers.priceIllustratedSimple'),  image: "/servicios/ilustrada-simple.webp" },
    { name: t('covers.illustratedComplex'), price: t('covers.priceIllustratedComplex'), image: "/servicios/ilustrada-compleja.webp" },
];
---

<Section>
    <Col class="items-start md:px-12 px-0">
        <Title class="md:text-6xl text-4xl md:leading-22">
            {t('covers.title')} <span class="italic">{t('covers.titleEmph')}</span>
        </Title>
        <Text class="mt-6 max-w-2xl text-secondary-500 text-lg leading-relaxed">
            {t('covers.subtitle')}
        </Text>
    </Col>
</Section>

<Section class="md:py-12 py-8">
    <Col class="md:gap-12 gap-8 w-full">
        {covers.map((cover) => (
            <Row class="w-full items-center md:gap-10 gap-6 flex-col md:flex-row">
                <div class="md:w-2/3 w-full">
                    <ZoomableImage src={cover.image} alt={cover.name} class="w-full h-auto object-contain rounded-xl" />
                </div>
                <Col class="md:w-1/3 w-full items-start gap-4">
                    <div class="flex flex-col gap-1">
                        <Title class="text-2xl md:text-3xl">{cover.name}</Title>
                        <span class="text-secondary-500 italic">{cover.price}</span>
                    </div>
                    <a href={localizedRoute('contact', lang)}>
                        <Button variant="primary">{t('common.requestQuote')}</Button>
                    </a>
                </Col>
            </Row>
        ))}
    </Col>
</Section>

<Section class="bg-primary-50 md:py-20 py-12">
    <Row class="items-center md:gap-12 gap-6 flex-col md:flex-row">
        <Col class="md:w-2/3 w-full items-start">
            <span class="text-primary font-simplify text-2xl md:text-3xl block mb-2">{t('covers.promoTag')}</span>
            <Title class="md:text-4xl text-2xl md:leading-12">
                {t('covers.promoTitleStart')}<span class="italic">{t('covers.promoTitleEmph')}</span>{t('covers.promoTitleEnd')}
            </Title>
        </Col>
        <Col class="md:w-1/3 w-full md:items-end items-start">
            <a href={localizedRoute('pack360', lang)}>
                <Button variant="primary" size="lg">{t('covers.promoCta')}</Button>
            </a>
        </Col>
    </Row>
</Section>
