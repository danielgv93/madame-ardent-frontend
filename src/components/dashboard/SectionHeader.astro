---
import Card from './Card.astro';

export interface Props {
    title: string;
    description?: string;
    class?: string;
}

const { title, description, class: additionalClass = "" } = Astro.props;
---

<Card title={title} description={description} class={additionalClass}>
    <Fragment slot="actions">
        <slot name="actions" />
    </Fragment>
</Card>
