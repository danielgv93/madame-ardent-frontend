---
import Card from './Card.astro';

const formRows = [
    { key: 'pending', label: 'Pendiente', bar: 'bg-yellow-400' },
    { key: 'read', label: 'Leído', bar: 'bg-blue-400' },
    { key: 'replied', label: 'Respondido', bar: 'bg-green-400' },
];

const orderRows = [
    { key: 'pending', label: 'Pendiente', bar: 'bg-yellow-400' },
    { key: 'paid', label: 'Pagado', bar: 'bg-blue-400' },
    { key: 'delivered', label: 'Entregado', bar: 'bg-green-400' },
    { key: 'failed', label: 'Fallido', bar: 'bg-red-400' },
    { key: 'refunded', label: 'Reembolsado', bar: 'bg-secondary-400' },
];

const iconForms = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`;
const iconOrders = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293A1 1 0 005.414 17H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`;
const iconRevenue = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
const iconPending = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
---

<section class="space-y-6">
    <div
        id="stats-error"
        class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
    >
        No se pudieron cargar las estadísticas. Intentá actualizar la página.
    </div>

    <!-- KPI cards (también funcionan como accesos directos) -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <a
            href="/dashboard/forms"
            class="group block bg-white rounded-2xl border border-secondary-100 shadow-sm p-5 transition-all duration-200 hover:shadow-md hover:border-primary-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-300"
        >
            <div class="flex items-start justify-between">
                <p class="text-xs font-semibold uppercase tracking-wider text-secondary-400 font-broskon">
                    Formularios
                </p>
                <div class="w-9 h-9 rounded-xl bg-blue-500 flex items-center justify-center shadow-sm">
                    <Fragment set:html={iconForms} />
                </div>
            </div>
            <p id="kpi-forms-total" class="mt-3 text-3xl text-secondary-900 font-simplify">—</p>
            <p class="mt-1 text-xs text-secondary-500">
                <span id="kpi-forms-week" class="font-semibold text-secondary-700">—</span> nuevos esta semana
            </p>
            <span class="mt-3 inline-flex items-center text-xs font-medium text-secondary-400 group-hover:text-primary transition-colors">
                Ver formularios →
            </span>
        </a>

        <a
            href="/dashboard/orders"
            class="group block bg-white rounded-2xl border border-secondary-100 shadow-sm p-5 transition-all duration-200 hover:shadow-md hover:border-primary-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-300"
        >
            <div class="flex items-start justify-between">
                <p class="text-xs font-semibold uppercase tracking-wider text-secondary-400 font-broskon">
                    Pedidos
                </p>
                <div class="w-9 h-9 rounded-xl bg-indigo-500 flex items-center justify-center shadow-sm">
                    <Fragment set:html={iconOrders} />
                </div>
            </div>
            <p id="kpi-orders-total" class="mt-3 text-3xl text-secondary-900 font-simplify">—</p>
            <p class="mt-1 text-xs text-secondary-500">
                <span id="kpi-orders-week" class="font-semibold text-secondary-700">—</span> nuevos esta semana
            </p>
            <span class="mt-3 inline-flex items-center text-xs font-medium text-secondary-400 group-hover:text-primary transition-colors">
                Ver pedidos →
            </span>
        </a>

        <a
            href="/dashboard/orders"
            class="group block bg-white rounded-2xl border border-secondary-100 shadow-sm p-5 transition-all duration-200 hover:shadow-md hover:border-primary-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-300"
        >
            <div class="flex items-start justify-between">
                <p class="text-xs font-semibold uppercase tracking-wider text-secondary-400 font-broskon">
                    Ingresos del mes
                </p>
                <div class="w-9 h-9 rounded-xl bg-emerald-500 flex items-center justify-center shadow-sm">
                    <Fragment set:html={iconRevenue} />
                </div>
            </div>
            <p id="kpi-month-revenue" class="mt-3 text-3xl text-secondary-900 font-simplify">—</p>
            <p class="mt-1 text-xs text-secondary-500">
                <span id="kpi-total-revenue" class="font-semibold text-secondary-700">—</span> acumulado
            </p>
            <span class="mt-3 inline-flex items-center text-xs font-medium text-secondary-400 group-hover:text-primary transition-colors">
                Ver pedidos →
            </span>
        </a>

        <a
            href="/dashboard/forms"
            class="group block bg-white rounded-2xl border border-secondary-100 shadow-sm p-5 transition-all duration-200 hover:shadow-md hover:border-primary-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-300"
        >
            <div class="flex items-start justify-between">
                <p class="text-xs font-semibold uppercase tracking-wider text-secondary-400 font-broskon">
                    Pendientes
                </p>
                <div class="w-9 h-9 rounded-xl bg-amber-500 flex items-center justify-center shadow-sm">
                    <Fragment set:html={iconPending} />
                </div>
            </div>
            <p id="kpi-pending-total" class="mt-3 text-3xl text-secondary-900 font-simplify">—</p>
            <p class="mt-1 text-xs text-secondary-500">
                <span id="kpi-pending-forms" class="font-semibold text-secondary-700">—</span> formularios ·
                <span id="kpi-pending-orders" class="font-semibold text-secondary-700">—</span> pedidos
            </p>
            <span class="mt-3 inline-flex items-center text-xs font-medium text-secondary-400 group-hover:text-primary transition-colors">
                Revisar formularios →
            </span>
        </a>
    </div>

    <!-- Status breakdowns -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <Card title="Formularios por estado">
            <div id="forms-breakdown" class="mt-2 space-y-3">
                {formRows.map((row) => (
                    <div class="flex items-center gap-3">
                        <span class="w-20 shrink-0 text-sm text-secondary-600">{row.label}</span>
                        <div class="flex-1 h-2.5 rounded-full bg-secondary-100 overflow-hidden">
                            <div
                                class={`h-full rounded-full ${row.bar} transition-all duration-500`}
                                style="width: 0%"
                                data-bar={row.key}
                            >
                            </div>
                        </div>
                        <span
                            class="w-8 text-right text-sm font-semibold text-secondary-900"
                            data-count={row.key}
                        >
                            0
                        </span>
                    </div>
                ))}
            </div>
        </Card>

        <Card title="Pedidos por estado">
            <div id="orders-breakdown" class="mt-2 space-y-3">
                {orderRows.map((row) => (
                    <div class="flex items-center gap-3">
                        <span class="w-20 shrink-0 text-sm text-secondary-600">{row.label}</span>
                        <div class="flex-1 h-2.5 rounded-full bg-secondary-100 overflow-hidden">
                            <div
                                class={`h-full rounded-full ${row.bar} transition-all duration-500`}
                                style="width: 0%"
                                data-bar={row.key}
                            >
                            </div>
                        </div>
                        <span
                            class="w-8 text-right text-sm font-semibold text-secondary-900"
                            data-count={row.key}
                        >
                            0
                        </span>
                    </div>
                ))}
            </div>
        </Card>
    </div>

    <!-- Recent activity -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <Card title="Últimos formularios">
            <div id="recent-forms" class="mt-1">
                <p class="py-4 text-center text-sm text-secondary-400">Cargando…</p>
            </div>
        </Card>

        <Card title="Últimos pedidos">
            <div id="recent-orders" class="mt-1">
                <p class="py-4 text-center text-sm text-secondary-400">Cargando…</p>
            </div>
        </Card>
    </div>
</section>

<script>
    import { authenticatedFetch } from '../../lib/client-api.ts';
    import { formatDate, escapeHtml } from '../../lib/utils.ts';
    import { formatPrice, fromCents, type Currency } from '../../lib/shop/currency.ts';
    import { FORM_STATUS_LABELS, FORM_STATUS_COLORS, type FormStatus } from '../../lib/constants/form-status.ts';
    import { ORDER_STATUS_LABELS, ORDER_STATUS_COLORS, type OrderStatus } from '../../lib/constants/order-status.ts';

    interface DashboardStats {
        forms: { total: number; thisWeek: number; pending: number; read: number; replied: number };
        orders: {
            total: number;
            thisWeek: number;
            pending: number;
            paid: number;
            delivered: number;
            failed: number;
            refunded: number;
            monthRevenueCents: number;
            totalRevenueCents: number;
        };
        recent: {
            forms: Array<{ id: string; name: string; email: string; status: FormStatus; createdAt: string }>;
            orders: Array<{
                id: string;
                email: string;
                status: OrderStatus;
                total: number;
                currency: Currency;
                createdAt: string;
            }>;
        };
    }

    const setText = (id: string, value: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    };

    // Revenue is stored mixed-currency in cents; shown with an EUR baseline.
    const formatRevenue = (cents: number) => formatPrice(fromCents(cents), 'EUR', 'es');

    function renderKpis(stats: DashboardStats) {
        setText('kpi-forms-total', String(stats.forms.total));
        setText('kpi-forms-week', String(stats.forms.thisWeek));
        setText('kpi-orders-total', String(stats.orders.total));
        setText('kpi-orders-week', String(stats.orders.thisWeek));
        setText('kpi-month-revenue', formatRevenue(stats.orders.monthRevenueCents));
        setText('kpi-total-revenue', formatRevenue(stats.orders.totalRevenueCents));
        setText('kpi-pending-total', String(stats.forms.pending + stats.orders.pending));
        setText('kpi-pending-forms', String(stats.forms.pending));
        setText('kpi-pending-orders', String(stats.orders.pending));
    }

    function renderBreakdown(containerId: string, counts: Record<string, number>, total: number) {
        const container = document.getElementById(containerId);
        if (!container) return;

        container.querySelectorAll<HTMLElement>('[data-bar]').forEach((bar) => {
            const key = bar.getAttribute('data-bar');
            if (!key) return;
            const count = counts[key] ?? 0;
            bar.style.width = total > 0 ? `${Math.round((count / total) * 100)}%` : '0%';
        });

        container.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
            const key = el.getAttribute('data-count');
            if (!key) return;
            el.textContent = String(counts[key] ?? 0);
        });
    }

    function renderRecentForms(forms: DashboardStats['recent']['forms']) {
        const container = document.getElementById('recent-forms');
        if (!container) return;

        if (forms.length === 0) {
            container.innerHTML =
                '<p class="py-4 text-center text-sm text-secondary-400">Sin formularios todavía</p>';
            return;
        }

        container.innerHTML = forms
            .map((form) => {
                const color = FORM_STATUS_COLORS[form.status] ?? 'bg-secondary-100 text-secondary-700';
                const label = FORM_STATUS_LABELS[form.status] ?? form.status;
                const id = encodeURIComponent(form.id);
                return `
                    <div class="py-3 border-b border-secondary-100 last:border-0">
                        <div class="flex items-center justify-between gap-3">
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-secondary-900 truncate">${escapeHtml(form.name)}</p>
                                <p class="text-xs text-secondary-500 truncate">${escapeHtml(form.email)}</p>
                            </div>
                            <span class="inline-flex shrink-0 px-2 py-0.5 text-xs font-semibold rounded-full ${color}">${escapeHtml(label)}</span>
                        </div>
                        <div class="mt-2 flex items-center justify-between gap-3">
                            <span class="text-xs text-secondary-400">${escapeHtml(formatDate(form.createdAt))}</span>
                            <div class="flex items-center gap-3">
                                <a href="/dashboard/forms?view=${id}" class="text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">Ver</a>
                                <a href="/dashboard/forms?reply=${id}" class="text-xs font-medium text-green-600 hover:text-green-800 transition-colors">Responder</a>
                            </div>
                        </div>
                    </div>
                `;
            })
            .join('');
    }

    function renderRecentOrders(orders: DashboardStats['recent']['orders']) {
        const container = document.getElementById('recent-orders');
        if (!container) return;

        if (orders.length === 0) {
            container.innerHTML =
                '<p class="py-4 text-center text-sm text-secondary-400">Sin pedidos todavía</p>';
            return;
        }

        container.innerHTML = orders
            .map((order) => {
                const color = ORDER_STATUS_COLORS[order.status] ?? 'bg-secondary-100 text-secondary-700';
                const label = ORDER_STATUS_LABELS[order.status] ?? order.status;
                const total = formatPrice(fromCents(order.total), order.currency, 'es');
                return `
                    <div class="flex items-center justify-between gap-3 py-2.5 border-b border-secondary-100 last:border-0">
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-secondary-900 truncate">${escapeHtml(order.email)}</p>
                            <p class="text-xs text-secondary-500 truncate">${escapeHtml(total)}</p>
                        </div>
                        <div class="text-right shrink-0">
                            <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-full ${color}">${escapeHtml(label)}</span>
                            <p class="text-xs text-secondary-400 mt-1">${escapeHtml(formatDate(order.createdAt))}</p>
                        </div>
                    </div>
                `;
            })
            .join('');
    }

    async function loadDashboardStats() {
        try {
            const response = await authenticatedFetch('/api/dashboard/stats');
            if (!response.ok) {
                showError();
                return;
            }

            const stats = (await response.json()) as DashboardStats;

            renderKpis(stats);
            renderBreakdown(
                'forms-breakdown',
                {
                    pending: stats.forms.pending,
                    read: stats.forms.read,
                    replied: stats.forms.replied,
                },
                stats.forms.total,
            );
            renderBreakdown(
                'orders-breakdown',
                {
                    pending: stats.orders.pending,
                    paid: stats.orders.paid,
                    delivered: stats.orders.delivered,
                    failed: stats.orders.failed,
                    refunded: stats.orders.refunded,
                },
                stats.orders.total,
            );
            renderRecentForms(stats.recent.forms);
            renderRecentOrders(stats.recent.orders);
        } catch (error) {
            console.error('Error loading dashboard stats:', error);
            showError();
        }
    }

    function showError() {
        document.getElementById('stats-error')?.classList.remove('hidden');
    }

    loadDashboardStats();
</script>
