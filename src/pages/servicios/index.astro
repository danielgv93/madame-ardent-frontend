---
import Layout from "../../layouts/Layout.astro";
import Section from "../../layouts/Section.astro";
import Title from "../../components/Title.astro";
import Text from "../../components/Text.astro";
import Row from "../../components/Row.astro";
import Col from "../../components/Col.astro";

const services = [
    {
        title: "Pack 360 para autores",
        description: "Todo lo que tu novela necesita para publicarse, desde la cubierta hasta el lanzamiento en redes.",
        href: "/servicios/pack-360",
        image: "/servicios/pack-360.webp",
    },
    {
        title: "Portadas de libros",
        description: "Cubiertas físicas comerciales para autopublicación o editorial tradicional.",
        href: "/servicios/portadas",
        image: "/servicios/simple.webp",
    },
    {
        title: "Maquetación interior",
        description: "Maquetación profesional para físico y digital, ajustada a la complejidad de tu obra.",
        href: "/servicios/maquetacion-interior",
        image: "/servicios/maquetacion-fisico.webp",
    },
    {
        title: "Ilustración",
        description: "Ilustraciones a medida para acompañar tu historia.",
        href: "/servicios/ilustracion",
        image: "/servicios/ilustrada-simple.webp",
    },
    {
        title: "Mapas",
        description: "Mapas ilustrados para mundos de fantasía y novelas con geografía propia.",
        href: "/servicios/mapas",
        image: "/servicios/ilustrada-compleja.webp",
    },
];
---

<Layout>
    <Section>
        <div class="md:w-2/3">
            <Title>
                Mis <span class="italic">Servicios</span>
            </Title>
            <Text class="mt-6 text-secondary-500 max-w-md text-lg leading-relaxed">
                Cada proyecto es único. Encontrá el servicio que mejor se ajusta a tu novela y empecemos a darle forma.
            </Text>
        </div>
    </Section>

    <Section class="md:py-12 py-8">
        <Row class="flex-wrap items-stretch md:gap-8 gap-6">
            {services.map((s) => (
                <Col class="md:w-[calc(33.333%-1.5rem)] w-full">
                    <a href={s.href} class="group w-full flex flex-col gap-4">
                        <div class="overflow-hidden rounded-xl aspect-[4/3]">
                            <img src={s.image} alt={s.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        </div>
                        <Title class="text-2xl md:text-3xl">{s.title}</Title>
                        <Text class="text-secondary-500">{s.description}</Text>
                    </a>
                </Col>
            ))}
        </Row>
    </Section>
</Layout>
