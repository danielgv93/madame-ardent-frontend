---
import Layout from "../../layouts/Layout.astro";
import Section from "../../layouts/Section.astro";
import Title from "../../components/Title.astro";
import Text from "../../components/Text.astro";
import Row from "../../components/Row.astro";
import Col from "../../components/Col.astro";
import Button from "../../components/Button.astro";
import BulletList from "../../components/BulletList.astro";

const personajes = [
    { label: "Diseño 1 personaje", price: "110€" },
    { label: "Diseño 2 personajes", price: "200€" },
    { label: "Fondo sencillo", price: "+45€" },
    { label: "Fondo complejo", price: "+110€" },
];

const packIncludes = [
    "Diseño de 4 personajes",
    "Cuerpo completo",
    "A color y blanco y negro",
    "Cualquier género, etnia y proporciones",
];
---

<Layout>
    <Section class="bg-primary-50 md:py-20 py-12">
        <Row class="items-center md:gap-12 gap-8 flex-col md:flex-row">
            <Col class="md:w-1/2 w-full">
                <img class="rounded-xl w-full" src="/servicios/ilustracion-1.webp" alt="Ilustraciones de personajes" />
            </Col>
            <Col class="md:w-1/2 w-full md:px-6 px-0 items-start">
                <Title class="md:text-5xl text-4xl md:leading-16">
                    Ilustraciones <span class="italic">de personajes</span>
                </Title>

                <ul class="flex flex-col gap-4 mt-8 w-full">
                    {personajes.map((item) => (
                        <li class="flex items-baseline justify-between gap-4 border-b border-primary/20 pb-3">
                            <Text>{item.label}</Text>
                            <span class="text-primary font-simplify text-2xl md:text-3xl whitespace-nowrap">{item.price}</span>
                        </li>
                    ))}
                </ul>

                <Text class="mt-6 text-secondary-500">
                    El fondo sencillo es como el mostrado en el ejemplo azul, monocromático. Si se desea un fondo plano como el amarillo no tendrá un costo adicional.
                </Text>

                <a href="/contacto" class="mt-8">
                    <Button variant="primary" size="lg">Solicita presupuesto</Button>
                </a>
            </Col>
        </Row>
    </Section>

    <Section class="md:py-20 py-12">
        <Row class="items-center md:gap-12 gap-8 flex-col md:flex-row">
            <Col class="md:w-1/2 w-full order-1">
                <img class="rounded-xl w-full" src="/servicios/ilustracion-2.webp" alt="Pack diseño de personajes" />
            </Col>
            <Col class="md:w-1/2 w-full md:px-6 px-0 items-start order-2">
                <Title class="md:text-5xl text-4xl md:leading-16">
                    Pack <span class="italic">diseño de personajes</span>
                </Title>

                <BulletList items={packIncludes} class="mt-8" />

                <div class="mt-8 flex flex-col gap-1">
                    <span class="text-secondary-500 text-sm">solo por</span>
                    <span class="text-primary font-simplify text-5xl md:text-6xl leading-none">399€</span>
                    <span class="text-secondary-500 text-sm italic">(opción de pago a plazos)*</span>
                </div>

                <a href="/contacto" class="mt-8">
                    <Button variant="primary" size="lg">Solicita presupuesto</Button>
                </a>
            </Col>
        </Row>
    </Section>

    <Section class="bg-primary-50 md:py-20 py-12">
        <Row class="items-center md:gap-12 gap-8 flex-col md:flex-row">
            <Col class="md:w-1/2 w-full">
                <Row class="gap-4 w-full">
                    <img class="rounded-xl w-1/2 h-auto object-cover" src="/servicios/ilustracion-3-1.webp" alt="Ilustración de siluetas 1" />
                    <img class="rounded-xl w-1/2 h-auto object-cover" src="/servicios/ilustracion-3-2.webp" alt="Ilustración de siluetas 2" />
                </Row>
            </Col>
            <Col class="md:w-1/2 w-full md:px-6 px-0 items-start">
                <Title class="md:text-5xl text-4xl md:leading-16">
                    Ilustraciones <span class="italic">de siluetas</span>
                </Title>

                <Text class="mt-6 text-secondary-500">
                    Se caracterizan por tener personajes poco detallados y dibujados con un color plano sobre un fondo llamativo y lleno de vida.
                </Text>

                <div class="mt-8 flex flex-col gap-1">
                    <span class="text-secondary-500 text-sm">desde</span>
                    <span class="text-primary font-simplify text-5xl md:text-6xl leading-none">130€</span>
                </div>

                <a href="/contacto" class="mt-8">
                    <Button variant="primary" size="lg">Solicita presupuesto</Button>
                </a>
            </Col>
        </Row>
    </Section>
</Layout>
