---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import SectionHeader from '../../components/dashboard/SectionHeader.astro';
import StatsCard from '../../components/dashboard/StatsCard.astro';
import Card from '../../components/dashboard/Card.astro';
import EmptyState from '../../components/dashboard/EmptyState.astro';
import Button from '../../components/Button.astro';
import Modal from '../../components/Modal.astro';
import { ORDER_STATUS, ORDER_STATUS_LABELS } from '../../lib/constants/order-status';
import { FORM_ICONS } from '../../lib/constants/icons';
import { SUPPORTED_CURRENCIES } from '../../lib/shop/currency';

const cartIcon = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293A1 1 0 005.414 17H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`;
const cashIcon = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
const clockIcon = `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
---

<DashboardLayout title="Pedidos">
    <div class="space-y-6">
        <SectionHeader
            title="Pedidos de la tienda"
            description="Gestioná las órdenes, descargas y reenvíos de email."
        >
            <Fragment slot="actions">
                <Button id="export-orders-btn" variant="action" size="sm" class="mr-2">
                    <Fragment set:html={FORM_ICONS.EXPORT} />
                    Exportar CSV
                </Button>
                <Button id="refresh-orders-btn" variant="secondary" size="sm">
                    <Fragment set:html={FORM_ICONS.REFRESH} />
                    Actualizar
                </Button>
            </Fragment>
        </SectionHeader>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
            <StatsCard title="Total" value="" icon={cartIcon} iconColor="bg-blue-500">
                <span id="stat-total">Cargando...</span>
            </StatsCard>
            <StatsCard title="Pendientes" value="" icon={clockIcon} iconColor="bg-yellow-500">
                <span id="stat-pending">Cargando...</span>
            </StatsCard>
            <StatsCard title="Esta semana" value="" icon={cartIcon} iconColor="bg-green-500">
                <span id="stat-week">Cargando...</span>
            </StatsCard>
            <StatsCard title="Ingresos del mes" value="" icon={cashIcon} iconColor="bg-emerald-500">
                <span id="stat-month-revenue">Cargando...</span>
            </StatsCard>
        </div>

        <Card>
            <div class="mb-4 grid grid-cols-1 md:grid-cols-4 gap-3">
                <select id="status-filter" class="border-gray-300 rounded-md shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="">Todos los estados</option>
                    {Object.values(ORDER_STATUS).map((s) => (
                        <option value={s}>{ORDER_STATUS_LABELS[s]}</option>
                    ))}
                </select>
                <select id="currency-filter" class="border-gray-300 rounded-md shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="">Todas las monedas</option>
                    {SUPPORTED_CURRENCIES.map((c) => <option value={c}>{c}</option>)}
                </select>
                <input id="date-from-filter" type="date" class="border-gray-300 rounded-md shadow-sm text-sm" />
                <input id="date-to-filter" type="date" class="border-gray-300 rounded-md shadow-sm text-sm" />
            </div>

            <div id="orders-loading" class="text-center py-8">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
                <p class="mt-2 text-sm text-gray-500">Cargando pedidos...</p>
            </div>

            <div id="orders-empty" class="hidden">
                <EmptyState
                    title="No hay pedidos"
                    description="Aún no se han recibido órdenes con los filtros seleccionados."
                    icon={cartIcon}
                />
            </div>

            <div id="orders-table" class="hidden overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pedido / Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer" data-sort-column="total">
                                Total <span class="sort-indicator text-blue-600"></span>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer" data-sort-column="status">
                                Estado <span class="sort-indicator text-blue-600"></span>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer" data-sort-column="createdAt">
                                Fecha <span class="sort-indicator text-blue-600">▼</span>
                            </th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody id="orders-tbody" class="bg-white divide-y divide-gray-200"></tbody>
                </table>
                <div id="orders-pagination" class="hidden"></div>
            </div>
        </Card>
    </div>

    <Modal id="order-modal" title="Detalle del pedido" maxWidth="xl">
        <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500">ID</label>
                    <p id="detail-id" class="text-sm font-mono text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Email</label>
                    <p id="detail-email" class="text-sm text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Estado</label>
                    <span id="detail-status"></span>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Moneda</label>
                    <p id="detail-currency" class="text-sm text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Subtotal</label>
                    <p id="detail-subtotal" class="text-sm text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Total</label>
                    <p id="detail-total" class="text-sm font-medium text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Creado</label>
                    <p id="detail-created" class="text-sm text-gray-900"></p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500">Pagado</label>
                    <p id="detail-paid" class="text-sm text-gray-900"></p>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-xs font-medium text-gray-500">Stripe Session</label>
                    <p id="detail-stripe" class="text-xs font-mono text-gray-700 break-all"></p>
                </div>
            </div>

            <div>
                <h4 class="text-sm font-medium text-gray-700 mb-2">Items y descargas</h4>
                <div id="detail-items" class="max-h-72 overflow-y-auto"></div>
            </div>

            <div id="resend-status" class="text-sm"></div>
        </div>

        <Fragment slot="footer">
            <Button id="resend-email-btn" variant="action" size="md" class="w-full sm:ml-3 sm:w-auto">
                Reenviar email
            </Button>
            <Button id="close-order-modal" variant="secondary" size="md" class="mt-3 w-full sm:mt-0 sm:w-auto">
                Cerrar
            </Button>
        </Fragment>
    </Modal>

    <Modal id="export-orders-modal" title="Exportar pedidos a CSV">
        <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label for="export-date-from" class="block text-sm font-medium text-gray-700 mb-1">Fecha desde:</label>
                    <input type="date" id="export-date-from" class="w-full border-gray-300 rounded-md shadow-sm text-sm" />
                </div>
                <div>
                    <label for="export-date-to" class="block text-sm font-medium text-gray-700 mb-1">Fecha hasta:</label>
                    <input type="date" id="export-date-to" class="w-full border-gray-300 rounded-md shadow-sm text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label for="export-status" class="block text-sm font-medium text-gray-700 mb-1">Estado:</label>
                    <select id="export-status" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                        <option value="">Todos</option>
                        {Object.values(ORDER_STATUS).map((s) => (
                            <option value={s}>{ORDER_STATUS_LABELS[s]}</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="export-currency" class="block text-sm font-medium text-gray-700 mb-1">Moneda:</label>
                    <select id="export-currency" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                        <option value="">Todas</option>
                        {SUPPORTED_CURRENCIES.map((c) => <option value={c}>{c}</option>)}
                    </select>
                </div>
            </div>
            <p class="text-sm text-gray-500">Dejá vacío lo que no quieras filtrar.</p>
        </div>

        <Fragment slot="footer">
            <Button id="confirm-export-orders" variant="action" size="md" class="w-full sm:ml-3 sm:w-auto">Exportar CSV</Button>
            <Button id="cancel-export-orders" variant="secondary" size="md" class="mt-3 w-full sm:mt-0 sm:w-auto">Cancelar</Button>
        </Fragment>
    </Modal>

    <script>
        import { OrdersManager } from '../../lib/orders-manager.ts';

        const manager = new OrdersManager();

        document.addEventListener('DOMContentLoaded', () => {
            manager.loadOrders();

            const on = (id: string, ev: string, fn: (e: Event) => void) => {
                const el = document.getElementById(id);
                if (el) el.addEventListener(ev, fn);
            };

            on('refresh-orders-btn', 'click', () => manager.loadOrders(1));
            on('export-orders-btn', 'click', () => manager.showExportModal());
            on('cancel-export-orders', 'click', () => manager.hideExportModal());
            on('confirm-export-orders', 'click', () => manager.exportCSV());
            on('close-order-modal', 'click', () => manager.hideModal());
            on('resend-email-btn', 'click', () => manager.resendEmail());

            ['status-filter', 'currency-filter', 'date-from-filter', 'date-to-filter'].forEach((id) => {
                on(id, 'change', () => manager.applyFilters());
            });

            document.addEventListener('click', (event) => {
                const target = event.target as HTMLElement;
                const view = target.closest('.view-order-btn') as HTMLElement | null;
                if (view) {
                    const id = view.dataset.orderId;
                    if (id) manager.viewOrder(id);
                    return;
                }
                const sortHeader = target.closest('[data-sort-column]') as HTMLElement | null;
                if (sortHeader) {
                    const col = sortHeader.getAttribute('data-sort-column');
                    if (col) manager.sortBy(col);
                    return;
                }
                const pageBtn = target.closest('.pagination-btn') as HTMLButtonElement | null;
                if (pageBtn && !pageBtn.disabled) {
                    const p = pageBtn.dataset.page;
                    if (p) manager.changePage(parseInt(p));
                }
            });
        });
    </script>
</DashboardLayout>
