---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Input from '../components/Input.astro';
import Label from '../components/Label.astro';
import Select from '../components/Select.astro';
import Textarea from '../components/Textarea.astro';
import Alert from '../components/Alert.astro';
---

<Layout title="Contacto - Madame Ardent">
  <main class="min-h-[calc(100vh-6rem)] bg-[#fee1e3] pt-12 pb-16">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="bg-white rounded-lg shadow-lg p-8 md:p-12 border border-[#d62013]/10">
        <h1 class="text-4xl md:text-5xl font-bold text-[#d62013] mb-8 text-center">Cuéntame tu historia</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10 text-gray-700 leading-relaxed">
          <div class="space-y-3">
            <p>Me inspiran las historias. Cuéntame todo sobre tu proyecto.</p>
            <p>Quiero trabajar contigo y crear portadas con las que soñamos. <span class="text-[#d62013] font-semibold">¡Escríbeme!</span></p>
          </div>
          <div class="md:border-l md:border-[#d62013]/20 md:pl-8">
            <p>
              Para cualquier otra consulta puedes contactarnos directamente a nuestro email:
            </p>
            <a href="mailto:info@madameardent.com" class="inline-block mt-2 text-[#d62013] hover:text-[#a01a0f] font-semibold underline underline-offset-4 decoration-[#d62013]/30 hover:decoration-[#d62013]">info@madameardent.com</a>
          </div>
        </div>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <Label for="name" required>Nombre</Label>
              <Input
                type="text"
                id="name"
                name="name"
                required
              />
            </div>

            <div>
              <Label for="user" required>Usuario en redes</Label>
              <Input
                type="text"
                id="user"
                name="user"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <Label for="email" required>Correo electrónico</Label>
              <Input
                type="email"
                id="email"
                name="email"
                required
              />
            </div>

            <div>
              <Label for="country" required>¿De dónde eres?</Label>
              <Input
                type="text"
                id="country"
                name="country"
                required
              />
            </div>
          </div>

          <div>
            <Label for="services" required>¿Qué servicios quieres contratar?</Label>
            <Select
              id="services"
              name="services"
              multi
              required
              placeholder="Selecciona uno o más servicios"
              options={[
                { value: 'Diseño de portada completa', label: 'Diseño de portada completa' },
                { value: 'Rediseño de portada existente', label: 'Rediseño de portada existente' },
                { value: 'Diseño de contraportada', label: 'Diseño de contraportada' },
                { value: 'Diseño de lomo', label: 'Diseño de lomo' },
                { value: 'Diseño completo (portada + contraportada + lomo)', label: 'Diseño completo (portada + contraportada + lomo)' },
                { value: 'Consultoría de diseño', label: 'Consultoría de diseño' },
                { value: 'Otro', label: 'Otro' },
              ]}
            />
          </div>

          <div>
            <Label for="budget" required>Presupuesto estimado (no será el final)</Label>
            <Select
              id="budget"
              name="budget"
              required
            >
              <option value="">Selecciona un presupuesto</option>
              <option value="200€">200€</option>
              <option value="300€">300€</option>
              <option value="400€">400€</option>
              <option value="+500€">+500€</option>
            </Select>
          </div>

          <div>
            <Label for="message" required>Mensaje</Label>
            <Textarea
              id="message"
              name="message"
              rows={5}
              required
              placeholder="Describe tu proyecto, presupuesto, plazos y cualquier detalle importante..."
            />
          </div>

          <div class="text-center">
            <Button
              type="submit"
              variant="primary"
              size="lg"
            >
              Enviar solicitud
            </Button>
          </div>
        </form>

        <Alert id="success-message" variant="success" hidden>
          ¡Mensaje enviado correctamente! Te contactaremos pronto.
        </Alert>

        <Alert id="error-message" variant="error" hidden>
          Error al enviar el mensaje. Por favor, inténtalo de nuevo.
        </Alert>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { ContactFormHandler } from '../lib/contact-form';

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('contact-form')) {
      new ContactFormHandler('contact-form');
    }
  });
</script>
